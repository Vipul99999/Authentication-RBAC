generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  HANDLER
  USER
}

enum ResetType {
  password
  pin
}

//////////////////////////////////////////////////////
// LOCATION TABLES (Normalized)
//////////////////////////////////////////////////////



model Address {
  id     Int    @id @default(autoincrement())
  state   String
  district String
  city    String
  village String
  pincode String @db.Char(6)
 
  users  User[]

  @@unique([state, district, city, village, pincode])
}


//////////////////////////////////////////////////////
// USERS (Core)
//////////////////////////////////////////////////////

model User {
  id              String   @id @default(uuid())

  phone           String   @unique
  email           String?  @unique

  passwordHash    String
  pinHash         String?

  isPinEnabled    Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)

  role            Role     @default(USER)

 //Address relation (optional, can be used for location-based access control)
  addressId       Int?
  address         Address? @relation(fields: [addressId], references: [id])
  // HIERARCHY
  createdById     String?
  createdBy       User?     @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers    User[]    @relation("UserCreator")

  // SECURITY
  failedAttempts  Int       @default(0)
  lockUntil       DateTime?

  createdAt       DateTime  @default(now())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////

  sessions        UserSession[]
  auditLogs       AuditLog[]
  oauthAccounts   OAuthAccount[]
  passwordResets  PasswordReset[]
}

//////////////////////////////////////////////////////
// SESSIONS (IMPORTANT)
//////////////////////////////////////////////////////

model UserSession {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken  String   // store hashed token
  ipAddress     String?
  userAgent     String?

  isActive      Boolean  @default(true)
  expiresAt     DateTime

  createdAt     DateTime @default(now())
   @@index([userId])
  @@index([refreshToken])
}



//////////////////////////////////////////////////////
// PASSWORD / PIN RESET
//////////////////////////////////////////////////////

model PasswordReset {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  token      String    // hashed token
  type       ResetType
  expiresAt  DateTime
  used       Boolean   @default(false)

  createdAt  DateTime  @default(now())
}

model OTP {
  id         Int      @id @default(autoincrement())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([phone])
}
//////////////////////////////////////////////////////
// GOOGLE OAUTH
//////////////////////////////////////////////////////

model OAuthAccount {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     String   // 'google'
  providerId   String
  email        String?

  createdAt    DateTime @default(now())

  @@unique([provider, providerId])
}

//////////////////////////////////////////////////////
// AUDIT LOGS
//////////////////////////////////////////////////////

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String
  metadata    Json?

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())
}

////// Email Verification (Optional, can be used for email verification tokens or similar)///

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}